{
  "name": "traceguard",
  "version": "0.1.0",
  "description": "Open-source trust layer for AI coding agents. Adds tool-boundary enforcement, evidence-linked claims, uncertainty labels, triggered verification, and auditable receipts to Claude Code and Codex CLI.",
  "type": "module",
  "bin": {
    "traceguard": "bin/traceguard.js",
    "tg": "bin/traceguard.js"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "TRACEguard_protocol.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "npm run build && chmod +x bin/traceguard.js || true"
  },
  "keywords": [
    "ai",
    "agents",
    "claude-code",
    "codex",
    "transparency",
    "audit",
    "governance",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "execa": "^9.5.1",
    "fast-glob": "^3.3.2",
    "picocolors": "^1.1.1",
    "simple-git": "^3.27.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
